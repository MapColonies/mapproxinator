{
  "name": "mapproxinator",
  "version": "1.2.5",
  "description": "This is a service that updates mapproxy.yaml file consistently",
  "main": "./src/index.ts",
  "scripts": {
    "test:unit": "jest --config=./tests/configurations/unit/jest.config.js",
    "test:integration": "jest --config=./tests/configurations/integration/jest.config.js",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prelint:fix": "npm run format:fix",
    "prelint": "npm run format",
    "lint:openapi": "redocly lint ./openapi3.yaml",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "npm run test:unit",
    "install": "npx husky install",
    "prebuild": "npm run clean",
    "build": "tsc --project tsconfig.build.json  && npm run assets:copy",
    "start": "npm run build && cd dist && node ./index.js",
    "assets:copy": "copyfiles -f ./config/* ./dist/config && copyfiles -f ./openapi3.yaml ./dist/ && copyfiles ./package.json dist",
    "clean": "rimraf dist"
  },
  "directories": {
    "test": "tests"
  },
  "author": "MapColonies",
  "license": "ISC",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@godaddy/terminus": "^4.12.1",
    "@map-colonies/error-express-handler": "^2.1.0",
    "@map-colonies/error-types": "^1.3.1",
    "@map-colonies/express-access-log-middleware": "^3.0.1",
    "@map-colonies/js-logger": "^5.0.0",
    "@map-colonies/openapi-express-viewer": "^3.0.0",
    "@map-colonies/read-pkg": "^2.0.0",
    "@map-colonies/telemetry": "^6.1.0",
    "@map-colonies/types": "^1.3.3",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/api-metrics": "0.23.0",
    "@opentelemetry/context-async-hooks": "^1.24.1",
    "@opentelemetry/instrumentation-express": "0.32.1",
    "@opentelemetry/instrumentation-http": "0.35.1",
    "aws-sdk": "^2.951.0",
    "compression": "^1.7.4",
    "config": "^4.2.0",
    "express": "^4.18.2",
    "express-openapi-validator": "^5.0.4",
    "http-status-codes": "^2.2.0",
    "pg": "^8.6.0",
    "reflect-metadata": "^0.1.13",
    "swagger-ui-express": "^4.1.6",
    "tsyringe": "^4.8.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@map-colonies/commitlint-config": "^2.0.0",
    "@map-colonies/eslint-config": "^8.0.0",
    "@map-colonies/prettier-config": "^1.0.0",
    "@map-colonies/tsconfig": "^2.0.0",
    "@redocly/cli": "^2.14.2",
    "@types/compression": "^1.7.2",
    "@types/config": "^3.3.5",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/js-yaml": "^4.0.1",
    "@types/multer": "^1.4.7",
    "@types/pg": "^8.6.1",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-express": "^4.1.3",
    "commitlint": "^17.6.6",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "jest-create-mock-instance": "^2.0.0",
    "jest-html-reporters": "^3.1.4",
    "js-yaml": "^4.1.0",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.0.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
